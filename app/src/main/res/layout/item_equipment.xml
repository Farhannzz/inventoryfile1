<?xml version="1.0" encoding="utf-8"?>
<!-- ===================================================================
     FILE: app/src/main/res/layout/item_equipment.xml
     Layout untuk satu baris item alat di RecyclerView Dashboard
     =================================================================== -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_item"
    android:elevation="2dp"
    android:padding="16dp">

    <!-- Nama Alat (judul utama, paling menonjol) -->
    <TextView
        android:id="@+id/tvNamaAlat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textColor="@color/spektrum_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvKondisi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Patient Monitor"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Chip Status Kondisi (warna dinamis diatur di EquipmentAdapter.kt) -->
    <TextView
        android:id="@+id/tvKondisi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chip_status"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Baik"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Merk & Tipe Alat -->
    <TextView
        android:id="@+id/tvMerkTipe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/spektrum_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNamaAlat"
        tools:text="Philips • IntelliVue MX450"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- QR Code -->
    <TextView
        android:id="@+id/tvQrCode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/spektrum_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMerkTipe"
        tools:text="QR: SPK-00123"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Lokasi Penempatan -->
    <TextView
        android:id="@+id/tvLokasi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/spektrum_text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvQrCode"
        tools:text="Ruang ICU Gedung A, Lt. 2 — RSUD Kota Spektrum"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Tanggal Inventory -->
    <TextView
        android:id="@+id/tvTanggal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#9AA5B1"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@id/btnDelete"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLokasi"
        tools:text="Diinventaris: 12 Juni 2026"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Tombol Hapus -->
    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Hapus data alat"
        android:src="@drawable/ic_delete"
        app:layout_constraintBottom_toBottomOf="@id/tvTanggal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTanggal" />

</androidx.constraintlayout.widget.ConstraintLayout>
