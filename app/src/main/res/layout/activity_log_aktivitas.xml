<?xml version="1.0" encoding="utf-8"?>
<!-- ===================================================================
     FILE: app/src/main/res/layout/activity_log_aktivitas.xml
     Halaman Log Aktivitas Teknisi -> Demonstrasi Internal Storage (Pertemuan 16)
     Menampilkan riwayat CRUD yang dibaca langsung dari file .txt internal storage
     =================================================================== -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spektrum_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.SpektrumInventory.Toolbar"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/spektrum_primary"
            app:navigationIcon="@drawable/ic_back"
            app:title="Log Aktivitas Teknisi"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/spektrum_primary_container"
        android:padding="12dp"
        android:text="📄 Data ini dibaca langsung dari file internal storage: log_aktivitas_teknisi.txt"
        android:textColor="@color/spektrum_primary"
        android:textSize="12sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp" />

        <TextView
            android:id="@+id/tvEmptyLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Belum ada aktivitas tercatat.\nLog akan otomatis muncul setiap kali Anda menambah, mengubah, atau menghapus data alat."
            android:textAlignment="center"
            android:textColor="@color/spektrum_text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHapusLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/status_rusak_text"
        android:text="Hapus Semua Log"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_delete" />

</LinearLayout>
