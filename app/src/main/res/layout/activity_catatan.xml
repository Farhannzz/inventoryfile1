<?xml version="1.0" encoding="utf-8"?>
<!-- ===================================================================
     FILE: app/src/main/res/layout/activity_catatan.xml
     Halaman Catatan Teknisi -> Demonstrasi Internal Storage Read & Write manual
     (Pertemuan 16). Teknisi bisa mengetik catatan bebas, lalu simpan/baca ulang.
     =================================================================== -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spektrum_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.SpektrumInventory.Toolbar"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/spektrum_primary"
            app:navigationIcon="@drawable/ic_back"
            app:title="Catatan Teknisi"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="📝 Tulis catatan/draft bebas di sini. Catatan akan tersimpan permanen di internal storage (catatan_teknisi.txt), tetap ada walau aplikasi ditutup."
            android:textColor="@color/spektrum_text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etCatatan"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edittext"
            android:gravity="top|start"
            android:hint="Contoh: Stok baterai cadangan untuk Patient Monitor di Gudang Lt.1 menipis, perlu order ulang minggu depan..."
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/spektrum_text_primary"
            android:textColorHint="#9AA5B1"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSimpanCatatan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/spektrum_primary"
            android:text="Simpan Catatan"
            android:textAllCaps="false"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_save" />

    </LinearLayout>

</LinearLayout>
