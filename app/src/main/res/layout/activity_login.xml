<?xml version="1.0" encoding="utf-8"?>
<!-- ===================================================================
     FILE: app/src/main/res/layout/activity_login.xml
     Layar Login / Daftar Akun -> tampil SEKALI di awal sebelum Dashboard.
     Pengganti Fitur 3 (Biometrik) karena sensor sidik jari kadang tidak
     stabil terdeteksi di sebagian perangkat.
     - Belum punya akun  -> tampil mode DAFTAR (Username, Password, Konfirmasi)
     - Sudah punya akun  -> tampil mode LOGIN  (Username, Password)
     =================================================================== -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spektrum_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Spacer atas agar konten tidak terlalu menempel ke status bar -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ============== ICON & JUDUL APLIKASI ============== -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_lock"
            android:tint="@color/spektrum_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:text="@string/app_name"
            android:textColor="@color/spektrum_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- ============== CARD FORM LOGIN / DAFTAR ============== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_item"
            android:padding="24dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvLoginTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Masuk ke Aplikasi"
                android:textColor="@color/spektrum_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLoginSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Masukkan username dan password Anda untuk melanjutkan."
                android:textColor="@color/spektrum_text_secondary"
                android:textSize="13sp" />

            <!-- Username -->
            <TextView
                style="@style/FieldLabel"
                android:text="Username" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edittext"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_profile"
                    android:tint="@color/spektrum_text_secondary" />

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Contoh: budi.santoso"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/spektrum_text_primary"
                    android:textColorHint="#9AA5B1"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Password -->
            <TextView
                style="@style/FieldLabel"
                android:text="Password" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_edittext"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_lock" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Minimal 4 karakter"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="@color/spektrum_text_primary"
                    android:textColorHint="#9AA5B1"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Konfirmasi Password -> HANYA muncul saat mode Daftar Akun -->
            <TextView
                android:id="@+id/tvLabelKonfirmasi"
                style="@style/FieldLabel"
                android:text="Konfirmasi Password"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/llKonfirmasiPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_edittext"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_lock" />

                <EditText
                    android:id="@+id/etKonfirmasiPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Ulangi password yang sama"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="@color/spektrum_text_primary"
                    android:textColorHint="#9AA5B1"
                    android:textSize="15sp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLoginSubmit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/spektrum_primary"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Masuk"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <!-- Spacer bawah -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ============== FOOTER IDENTITAS ============== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/footer_identitas"
            android:textColor="@color/spektrum_text_secondary"
            android:textSize="11sp" />

    </LinearLayout>

</ScrollView>
