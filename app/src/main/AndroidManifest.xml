<?xml version="1.0" encoding="utf-8"?>
<!-- ===================================================================
     FILE: app/src/main/AndroidManifest.xml  (VERSI FINAL — gunakan ini)
     Menggantikan file 02_AndroidManifest.xml sebelumnya, sudah termasuk
     FileProvider untuk fitur Export PDF dan pendaftaran SpektrumApplication.
     =================================================================== -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Izin untuk Notifikasi Lokal (Wajib runtime permission di Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SpektrumApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Spektrum Inventory"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpektrumInventory">

        <!-- Layar Login/Daftar Akun -> SEKARANG menjadi launcher activity,
             pengganti Fitur 3 (Biometrik). Wajib login dulu sebelum Dashboard tampil. -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.FormActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <!-- Halaman Log Aktivitas Teknisi -> demonstrasi membaca file dari Internal Storage -->
        <activity
            android:name=".ui.LogAktivitasActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <!-- Halaman Catatan Teknisi -> demonstrasi tulis/baca file Internal Storage secara manual -->
        <activity
            android:name=".ui.CatatanActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <!-- FileProvider: diperlukan agar file PDF di internal storage bisa
             dibuka aplikasi PDF viewer eksternal (lihat MainActivity.offerToOpenPdf) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
